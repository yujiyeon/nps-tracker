# ── 공통 ──────────────────────────────────────────
# Railway 내부 서비스 참조: ${{ServiceName.VARIABLE_NAME}} 형식
# 아래는 실제 Railway 대시보드에서 설정할 값들

# ── PostgreSQL (TimescaleDB) ──────────────────────
# Railway에서 timescaledb 서비스 생성 후 자동 주입되거나 직접 입력
POSTGRES_PASSWORD=your-strong-password-here

# api/data-collector 서비스에 설정
DATABASE_URL=postgresql+psycopg2://nps_user:${POSTGRES_PASSWORD}@nps-db.railway.internal:5432/nps_tracker

# ── Redis ─────────────────────────────────────────
# Railway Redis 플러그인 추가 후 자동 주입: ${{Redis.REDIS_URL}}
REDIS_URL=redis://default:password@redis.railway.internal:6379

# ── API 서비스 ─────────────────────────────────────
LOG_LEVEL=INFO
# web 서비스의 Railway public URL (예: https://nps-web-xxx.railway.app)
ALLOWED_ORIGINS=https://your-web-domain.railway.app

# ── Web 서비스 ─────────────────────────────────────
# api 서비스의 Railway internal URL (서비스 간 통신)
NEXT_PUBLIC_API_URL=https://your-api-domain.railway.app

# ── Data Collector ─────────────────────────────────
DART_API_KEY=your-dart-api-key
